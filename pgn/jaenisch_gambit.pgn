 (4. exf5 {Jaenisch Gambit Accepted}
  4... e4 5. Bxc6
   (5. Qe2 Qe7 $1 6. Bxc6 $1
     (6. Ng1 $2 6... Nd4 {attacks the queen, the bishop, the pawn on f5 and threatens to win the rook with Nxc2+}
      7. Qc4 $2 {temporarily defends everything except the f-pawn while attacking the knight and the c-pawn}
       (7. Qh5+ Kd8 8. Ba4 Nf6 9. Qd1
         (9. Qh3 d5)
         (9. Qg5 b5 10. Bb3 a5 11. c3 h6 12. Qf4 a4 13. Bxa4 g5 14. fxg6 Ne6)
         (9. Qh4 b5 10. Bb3 a5 11. c3 Nxf5 12. Qh3 d5)
        9... b5 10. Bb3 c5 11. c3 Nxf5 12. Ne2 c4 13. Bc2 Qe5)
      7... Qe5 {defends the knight and threatens Nxb5}
      8. Qc3 {pins the knight}
       (8. Ba4 b5 9. Bxb5 Nxb5)
       (8. Nc3 c6 {attacks the bishop and controls d5, preventing Qd5 which would complicate the position}
        9. Ba4 b5 10. Bxb5 cxb5 11. Nxb5
         (11. Qd5 Qxd5 12. Nxd5 Nxc2+ 13. Kd1 Nxa1 14. Nc7+)
        11... Nxb5)
       (8. Ne2 Nxb5 $1)
      8... Bb4 $3 {develops the bishop with tempo}
      9. Qc4 {keeping the pressure on both minor pieces}
       (9. Qxb4 $4 9... Nxc2+ $1 {wins the queen})
      9... Be7 {threatens Nxb5 once again}
       (9... Bd6 $5 {looks like a good idea since it defends the queen, so Nxb5 can't be prevented with Qc3}
        10. Ne2 {gains control over d4}
        10... Nxb5 11. a4 {the knight is trapped}
        11... a6 {prepares Na7}
        12. d4
         (12. axb5 $6 12... axb5 {attacks queen and rook}
          13. Rxa8
           (13. Qb3 $2 13... Rxa1)
          13... bxc4 14. Rxc8+ Kf7)
        12... exd3 13. Qxd3 Na7)
      10. Qc3 {black successfully developed the bishop to e7 while white didn't make any progress}
      10... Nh6 {prepares to win back the pawn while preventing g4}
      11. Ne2 {attacks the pinned piece}
      11... Nhxf5 {wins back the pawn while defending the knight on d4}
      12. g4 {tries to win the knight on d4 by removing one defender}
       (12. b3 {prepares to add more pressure on the pinned knight by fianchettoing the bishop}
        12... Bb4 {same trap as before, but this time to prevent Bb2}
        13. Qc4
